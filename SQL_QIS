CREATE PROCEDURE dbo.GetRiskFactorData
    @BloombergCodes NVARCHAR(MAX),  -- Comma-separated Bloomberg codes
    @StartDate DATE
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @sql NVARCHAR(MAX);
    
    -- Generate dynamic pivot columns
    DECLARE @PivotColumns NVARCHAR(MAX) = '';
    DECLARE @SelectColumns NVARCHAR(MAX) = '';

    -- Convert Bloomberg codes into dynamic column names
    SELECT 
        @PivotColumns = STRING_AGG('MAX(CASE WHEN BloombergCode = ''' + value + ''' THEN TSValue END) AS [' + value + '_TSValue], 
                                    MAX(CASE WHEN BloombergCode = ''' + value + ''' THEN ACCode END) AS [' + value + '_ACCode]', ', '),
        @SelectColumns = STRING_AGG('[' + value + '_TSValue], [' + value + '_ACCode]', ', ')
    FROM STRING_SPLIT(@BloombergCodes, ',');

    -- Construct the full dynamic SQL query
    SET @sql = '
    WITH FilteredData AS (
        SELECT 
            rfts.TSDate,
            rf.BloombergCode,
            rfts.TSValue,
            rf.ACCode
        FROM dbo.RiskFactor rf (NOLOCK)
        LEFT JOIN dbo.RiskFactorTSLatestView rfts WITH(NOLOCK)
            ON rfts.RiskFactorId = rf.RiskFactorId
        WHERE rf.BloombergCode IN (' + QUOTENAME(@BloombergCodes, '''') + ')
        AND rfts.TSDate > @StartDate
    )
    SELECT TSDate, ' + @PivotColumns + '
    FROM FilteredData
    GROUP BY TSDate
    ORDER BY TSDate ASC;';

    -- Execute dynamic SQL
    EXEC sp_executesql @sql, N'@StartDate DATE', @StartDate;
END;
